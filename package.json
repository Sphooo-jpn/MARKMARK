{
  "name": "markmark",
  "version": "1.1.0",
  "description": "MARKMARK — Typora風インラインWYSIWYG Markdownエディタ",
  "main": "out/main/index.js",
  "author": "Sphooo-jpn",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:regression": "vitest run tests/regression",
    "dist": "electron-vite build && electron-builder --win",
    "dist:dir": "electron-vite build && electron-builder --win --dir"
  },
  "build": {
    "appId": "com.sphooo.markmark",
    "productName": "MARKMARK",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown Document",
        "description": "Markdown Document",
        "icon": "build/md.ico",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown Document",
        "description": "Markdown Document",
        "icon": "build/md.ico",
        "role": "Editor"
      }
    ],
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": false,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MARKMARK",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "artifactName": "MARKMARK-Setup-${version}.${ext}"
    }
  },
  "devDependencies": {
    "@milkdown/crepe": "^7.21.2",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "happy-dom": "^20.10.6",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  }
}
